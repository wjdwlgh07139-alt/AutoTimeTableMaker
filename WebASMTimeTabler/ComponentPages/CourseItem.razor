@using WebASMTimeTabler.Core
@using Microsoft.AspNetCore.Components

<tr @key="Course.ClassNumber" 
    style="border-bottom: 1px solid var(--border-color); 
           color: #0E201C; 
           font-size: 0.88rem; 
           font-weight: 500;
           background-color: @(IsSelected ? "#D2E8E1" : "transparent");">
    <td style="padding: 12px 0;">
        <input type="checkbox" class="form-check-input" checked="@IsSelected" @onclick="ToggleCourse" style="cursor: pointer; border-color: var(--heritage-green-light);" />
    </td>
    <td style="padding: 12px 0;">@Course.Grade</td>
    <td style="padding: 12px 0;">@Course.Credit</td>
    <td style="padding: 12px 0; font-family: monospace; font-size: 0.82rem;">@Course.CourseID</td>
    <td style="padding: 12px 0; font-family: monospace; font-size: 0.82rem;">@Course.CourseNumber</td>
    <td style="padding: 12px 0;">@Course.Division</td>
    <td style="padding: 12px 0; font-family: monospace; font-size: 0.82rem;">@Course.ClassNumber</td>
    <td class="text-start" style="font-size: 0.82rem; color: #405753; padding: 12px 0 12px 6px;">@string.Join(", ", Course.Times)</td>
    <td class="text-start fw-semibold" style="color: var(--heritage-green); padding: 12px 0 12px 6px;">@Course.Name</td>
    <td style="padding: 12px 0;">
        @if (HasMultipleProfessors)
        {
            <span @onclick="ToggleProfessorPopup" style="cursor:pointer; text-decoration:underline; color:var(--heritage-green-light); font-weight: 600;">
                @FirstProfessor <span style="font-size:0.8em; color: var(--text-secondary); text-decoration: none; font-weight: normal;">외</span>
            </span>
            <CourseProfessorPopup Course="Course" Visible="showProfessorPopup" OnClose="CloseProfessorPopup" />
        }
        else
        {
            @Course.Professor
        }
    </td>
    <td style="padding: 12px 0;">@Course.Time</td>
</tr>

@code{
    [Parameter] public Course Course { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback<Course> OnToggleSelection { get; set; }

    private bool showProfessorPopup = false;

    private void ToggleCourse() => OnToggleSelection.InvokeAsync(Course);

    private void ToggleProfessorPopup()
    {
        showProfessorPopup = !showProfessorPopup;
    }

    private void CloseProfessorPopup() => showProfessorPopup = false;

    private string GetSelectedClass() => IsSelected ? "table-primary" : "";

    // 문자열 처리 캐싱
    private bool HasMultipleProfessors => Course.Professor.Contains(",");
    private string FirstProfessor => Course.Professor.Split(',')[0];
}
