@page "/courses"
@using WebASMTimeTabler.Core
@using WebASMTimeTabler.ComponentPages
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ScheduleStateService StateService

<PageTitle>강의 목록 - Timeship</PageTitle>

<h2 class="fw-bold mb-1" style="color: var(--heritage-green); letter-spacing: -0.5px;">강의 목록</h2>
<p class="text-secondary small mb-4">수강하려는 과목을 선택하여 시간표 조합을 생성해 보세요.</p>

<div class="mb-4">
    <input type="text" 
            class="form-control py-2 shadow-sm" 
            style="border-radius: 10px; border: 1px solid var(--border-color); font-size: 0.95rem;"
            placeholder="과목명, 교수명, 과목번호로 검색" 
            value="@StateService.SearchTerm" 
            @oninput="OnSearchTermChanged" />
</div>

@if (StateService.AllCourses == null)
{
    <p><em>Loading...</em></p>
}
else
{   
    <div class="mb-3 d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-success fw-medium px-3" style="border-radius: 6px;" @onclick="SelectAllFiltered">현재 목록 전체 선택</button>
        <button type="button" class="btn btn-sm btn-outline-danger fw-medium px-3" style="border-radius: 6px;" @onclick="DeselectAllFiltered">현재 목록 전체 해제</button>
    </div>
    
    <div class="card p-3 mb-4 border-0" style="border-radius: 12px; background-color: var(--heritage-green-pale); box-shadow: var(--card-shadow);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="fw-bold mb-0 d-flex align-items-center" style="color: var(--heritage-green); font-size: 1.05rem;">
                <span>선택된 과목 (@StateService.SelectedCourses.Count)개</span>
                <button type="button" class="btn btn-sm btn-link text-decoration-none ms-2" style="font-size: 0.85rem; color: var(--heritage-green-light);" @onclick="ToggleSelectedCourses">
                    @(showSelectedCourses ? "▲ 접기" : "▼ 펼치기")
                </button>
            </h5>
            <button type="button" class="btn btn-primary fw-bold btn-sm shadow-sm" style="border-radius: 6px;" @onclick="GoToTimeTabler">시간표 생성하러 가기 &rarr;</button>
        </div>

        @if (showSelectedCourses)
        {
            <div class="mt-3">
                @if (StateService.SelectedCourses.Count == 0)
                {
                    <p class="text-secondary small mb-0"><em>선택된 과목이 없습니다.</em></p>
                }
                else
                {
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var course in StateService.SelectedCourses)
                        {
                            <div @key="course.ClassNumber" class="d-inline-flex align-items-center bg-white border px-3 py-1 rounded-pill" style="font-size: 0.85rem; border-color: var(--border-color) !important;">
                                <span class="fw-medium text-dark me-2">@course.Name (@course.Professor)</span>
                                <button type="button" class="btn btn-sm p-0 text-danger fw-bold" style="line-height: 1; font-size: 0.9rem;" @onclick="() => RemoveCourse(course)">&times;</button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (string.IsNullOrWhiteSpace(StateService.SearchTerm))
    {
        <div class="text-center py-5 rounded-4" style="background-color: var(--heritage-green-pale); border: 1px dashed var(--border-color); color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="var(--heritage-green-light)" class="bi bi-search mb-3" viewBox="0 0 16 16">
              <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
            </svg>
            <h5 class="fw-bold" style="color: var(--heritage-green);">과목 검색을 시작해 보세요</h5>
            <p class="small mb-0">과목명, 교수명, 또는 과목번호를 입력하시면 수강 가능한 강의 목록이 노출됩니다.</p>
        </div>
    }
    else if (filteredCourses.Count == 0)
    {
        <div class="text-center py-5 rounded-4" style="background-color: var(--heritage-green-pale); border: 1px dashed var(--border-color); color: var(--text-secondary);">
            <p class="mb-0">검색 조건에 맞는 과목이 없습니다. 다시 입력해 주세요.</p>
        </div>
    }
    else
    {
        <!-- 데스크탑 뷰: 테이블 구조 (Virtualize 포함) -->
        <div class="d-none d-md-block card border-0 p-3" style="border-radius: 16px; box-shadow: var(--card-shadow); background-color: var(--surface-white); overflow-x: auto;">
            <table class="table text-center align-middle" style="table-layout: fixed; width: 100%; border: none; margin-bottom: 0;">
                <thead>
                    <tr style="background-color: var(--heritage-green); color: var(--possibility-white);">
                        <th style="width: 50px; font-weight: 600; border: none; border-radius: 8px 0 0 8px; padding: 12px 0;">선택</th>
                        <th style="width: 50px; font-weight: 600; border: none; padding: 12px 0;">학년</th>
                        <th style="width: 50px; font-weight: 600; border: none; padding: 12px 0;">학점</th>
                        <th style="width: 90px; font-weight: 600; border: none; padding: 12px 0;">학수번호</th>
                        <th style="width: 90px; font-weight: 600; border: none; padding: 12px 0;">교과번호</th>
                        <th style="width: 80px; font-weight: 600; border: none; padding: 12px 0;">이수구분</th>
                        <th style="width: 80px; font-weight: 600; border: none; padding: 12px 0;">과목번호</th>
                        <th style="width: 250px; font-weight: 600; border: none; padding: 12px 0;">시간</th>
                        <th style="width: 230px; font-weight: 600; border: none; padding: 12px 0;">교과목명</th>
                        <th style="width: 90px; font-weight: 600; border: none; padding: 12px 0;">교수명</th>
                        <th style="width: 80px; font-weight: 600; border: none; border-radius: 0 8px 8px 0; padding: 12px 0;">교과시간</th>
                    </tr>
                </thead>
                <tbody>
                    <Virtualize Items="@filteredCourses" Context="course" ItemSize="53" OverscanCount="50">
                        <CourseItem @key="course.ClassNumber" Course="course" IsSelected="IsSelected(course)" OnToggleSelection="ToggleCourse" />
                    </Virtualize>
                </tbody>
            </table>
        </div>

        <!-- 모바일 뷰: 카드형 리스트 구조 -->
        <div class="d-block d-md-none" style="padding-bottom: 5rem;">
            @foreach (var course in filteredCourses)
            {
                var isSel = IsSelected(course);
                <div @key="course.ClassNumber" 
                     class="card mb-3 p-3 border-0 transition-all text-start" 
                     style="border-radius: 12px; 
                            background-color: @(isSel ? "var(--heritage-green-pale)" : "var(--surface-white)"); 
                            box-shadow: var(--card-shadow);
                            cursor: pointer;
                            border: 1px solid @(isSel ? "var(--heritage-green-light)" : "transparent") !important;"
                     @onclick="() => ToggleCourse(course)">
                    
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <div class="fw-bold text-dark" style="font-size: 0.95rem; line-height: 1.3;">
                            @course.Name
                        </div>
                        <span class="badge rounded-pill fw-semibold border ms-2" 
                              style="font-size: 0.7rem; 
                                     background-color: @(isSel ? "var(--heritage-green)" : "var(--heritage-green-pale)"); 
                                     color: @(isSel ? "var(--possibility-white)" : "var(--heritage-green)");
                                     border-color: var(--heritage-green-light) !important;">
                            @course.Division
                        </span>
                    </div>

                    <div class="d-flex align-items-center gap-2 mb-2 text-secondary" style="font-size: 0.8rem;">
                        <span class="fw-semibold text-dark">@course.Professor</span>
                        <span>&middot;</span>
                        <span>@(course.Grade)학년</span>
                        <span>&middot;</span>
                        <span>@(course.Credit)학점</span>
                        <span>&middot;</span>
                        <span class="font-monospace text-muted" style="font-size: 0.75rem;">@course.ClassNumber</span>
                    </div>

                    <div class="text-start" style="font-size: 0.78rem; color: var(--heritage-green-light); font-weight: 600;">
                        @if (course.Times != null && course.Times.Count > 0)
                        {
                            <span>@string.Join(" / ", course.Times.Select(GetMobileFormattedTime))</span>
                        }
                        else
                        {
                            <span>@(string.IsNullOrWhiteSpace(course.Time) ? "시간 정보 없음" : course.Time)</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
}

@code {

    
    private bool debounceFlag = true;

    //검색 기능 및 필터링

    private IList<Course> filteredCourses = new List<Course>();
    private async Task OnSearchTermChanged(ChangeEventArgs e)
    {
        StateService.SearchTerm = e.Value?.ToString() ?? string.Empty;
        bool currentFlag = debounceFlag = !debounceFlag; // true/false 번갈아 저장
        await Task.Delay(100); // 300ms 대기

        if (currentFlag == debounceFlag) // 최신 입력만 반영
        {
            await Task.Run(() => ApplyFilter());
        }
    }
    private void ApplyFilter()
    {
        if (StateService.AllCourses == null) return;

        var term = StateService.SearchTerm;
        if (string.IsNullOrWhiteSpace(term))
        {
            filteredCourses = new List<Course>();
        }
        else
        {
            var list = StateService.AllCourses.Where(c => 
                c.Name.Contains(term, StringComparison.OrdinalIgnoreCase) || 
                c.Professor.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                c.ClassNumber.Contains(term, StringComparison.OrdinalIgnoreCase));

            filteredCourses = list.ToList();
        }
        StateHasChanged();
    }

    //전체선택 및 해제기능
    private bool showSelectedCourses = false;

    private void ToggleSelectedCourses()
    {
        showSelectedCourses = !showSelectedCourses;
    }
    private void SelectAllFiltered()
    {
        foreach (var c in filteredCourses)
            if(!StateService.IsSelected(c)) StateService.ToggleCourse(c);
        StateHasChanged();
    }

    private void DeselectAllFiltered()
    {
        foreach(var course in filteredCourses)
            if(StateService.IsSelected(course)) StateService.ToggleCourse(course);
        StateHasChanged();
    }

    private void RemoveCourse(Course course)
    {
        StateService.SelectedCourses.Remove(course);
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        // courses가 null일 때만 데이터를 로드 (최초 1회)
        if (StateService.AllCourses == null)
        {
            try
            {
                StateService.AllCourses = await Http.GetFromJsonAsync<Course[]>("sample-data/courses.json");
                ApplyFilter();
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Error loading courses: {ex.Message}");
                // 로딩 실패 시 사용자에게 알리는 UI 로직 추가 가능
            }
        }
        else
        {
            // 이미 로딩된 데이터가 있다면 필터만 다시 적용
            ApplyFilter();
        }
    }

    private void ToggleCourse(Course course)
    {
        StateService.ToggleCourse(course);
        StateHasChanged();
    }

    private bool IsSelected(Course course) => StateService.SelectedCourses.Contains(course);

    private void GoToTimeTabler()
    {
        StateService.autoGenerateOnLoad = true;
        NavManager.NavigateTo("/timetable");
    }

    private string GetMobileFormattedTime(CourseTime t)
    {
        var dayStr = t.day switch
        {
            WebASMTimeTabler.Core.DayOfWeek.월 => "월",
            WebASMTimeTabler.Core.DayOfWeek.화 => "화",
            WebASMTimeTabler.Core.DayOfWeek.수 => "수",
            WebASMTimeTabler.Core.DayOfWeek.목 => "목",
            WebASMTimeTabler.Core.DayOfWeek.금 => "금",
            WebASMTimeTabler.Core.DayOfWeek.토 => "토",
            WebASMTimeTabler.Core.DayOfWeek.일 => "일",
            WebASMTimeTabler.Core.DayOfWeek.e러닝 => "e러닝",
            _ => "알수없음"
        };

        if (t.day == WebASMTimeTabler.Core.DayOfWeek.e러닝)
        {
            return "e러닝";
        }

        var startMin = 9 * 60 + (t.start - 1) * 30;
        var endMin = 9 * 60 + (t.end - 1) * 30 + 30;

        var startHourStr = $"{startMin / 60:D2}:{startMin % 60:D2}";
        var endHourStr = $"{endMin / 60:D2}:{endMin % 60:D2}";

        var roomStr = string.IsNullOrWhiteSpace(t.Room) ? "강의실 미지정" : t.Room;

        return $"{dayStr}, {startHourStr}~{endHourStr}, {roomStr}";
    }
}