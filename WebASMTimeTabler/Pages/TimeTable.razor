@page "/timetable"
@using WebASMTimeTabler.Core
@using CoreDay = WebASMTimeTabler.Core.DayOfWeek
@inject ScheduleStateService StateService

<PageTitle>시간표</PageTitle>


<div class="d-flex gap-4 align-items-start">
    <div class="card p-4 flex-shrink-0 border-0" style="width: 340px; border-radius: 16px; background-color: var(--surface-white); box-shadow: var(--card-shadow); font-size: 0.95rem; position: sticky; top: 5rem; z-index: 10;">
        <h5 class="fw-bold mb-3" style="color: var(--heritage-green); letter-spacing: -0.5px;">필터 설정</h5>
        
        <h6 class="fw-semibold text-secondary mt-2 mb-3" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">실시간 필터 (Realtime)</h6>
        
        <div class="form-check mb-2 d-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input m-0" id="lunchBreak" @bind="StateService.useLunchBreak" style="cursor: pointer;">
            <label class="form-check-label" for="lunchBreak" style="cursor: pointer;">점심시간 공강 (12:00-13:00)</label>
        </div>

        <div class="form-check mb-2 d-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input m-0" id="morningFilter" @bind="StateService.useMorningFilter" style="cursor: pointer;">
            <label class="form-check-label" for="morningFilter" style="cursor: pointer;">아침 수업 금지 (10시 이전)</label>
        </div>

        <div class="form-check mb-2 d-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input m-0" id="noDayFilter" @bind="StateService.useNoDayFilter" style="cursor: pointer;">
            <label class="form-check-label" for="noDayFilter" style="cursor: pointer;">특정 요일 공강</label>
        </div>
        @if (StateService.useNoDayFilter)
        {
            <div class="ms-1 my-2 d-flex gap-1 flex-wrap">
                @foreach (var day in Enum.GetValues<CoreDay>().Where(d => d >= CoreDay.월 && d <= CoreDay.토))
                {
                    var isChecked = StateService.NoDays.Contains(day);
                    <button type="button" class="btn btn-sm px-2 py-1 rounded-pill border-0 transition-all text-nowrap"
                            style="font-size: 0.8rem;
                                   background-color: @(isChecked ? "var(--heritage-green)" : "var(--heritage-green-pale)");
                                   color: @(isChecked ? "var(--possibility-white)" : "var(--text-primary)");
                                   font-weight: 500;"
                            @onclick="@(_ => StateService.ToggleNoDay(day))">
                        @day.ToString()
                    </button>
                }
            </div>
        }

        <div class="form-check mb-2">
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" class="form-check-input m-0" id="maxConsecutive" @bind="StateService.useMaxConsecutive" style="cursor: pointer;">
                <label class="form-check-label" for="maxConsecutive" style="cursor: pointer;">연강 제한 (최대 @StateService.maxConsecutiveHours 시간)</label>
            </div>
        </div>
        <div class="ms-4 mb-2" style="display: @(StateService.useMaxConsecutive ? "block" : "none")">
            <input type="number" class="form-control form-control-sm" @bind="StateService.maxConsecutiveHours" min="1" max="10" />
        </div>

        <div class="form-check mb-2">
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" class="form-check-input m-0" id="breakTimeFilter" @bind="StateService.useBreakTimeFilter" style="cursor: pointer;">
                <label class="form-check-label" for="breakTimeFilter" style="cursor: pointer;">특정 시간대 공강</label>
            </div>
        </div>
        <div class="ms-4 mb-2" style="display: @(StateService.useBreakTimeFilter ? "block" : "none")">
            <div class="row g-1">
                <div class="col-4">
                    <select class="form-select form-select-sm" @bind="StateService.tempBreakTimeDay">
                        @foreach (var day in Enum.GetValues<CoreDay>().Where(d => d >= CoreDay.월 && d <= CoreDay.금))
                        {
                            <option value="@day">@day.ToString()</option>
                        }
                    </select>
                </div>
                <div class="col-3">
                    <input type="number" class="form-control form-control-sm" @bind="StateService.tempBreakTimeStartHour" min="9" max="23" />
                </div>
                <div class="col-3">
                    <input type="number" class="form-control form-control-sm" @bind="StateService.tempBreakTimeEndHour" min="9" max="24" />
                </div>
                <div class="col-2">
                    <button type="button" class="btn btn-sm btn-outline-success w-100" style="padding: .25rem .25rem; font-weight: 500;" @onclick="AddBreakRule">추가</button>
                </div>
            </div>
            <div class="mt-2" style="max-height: 150px; overflow-y: auto;">
                @foreach (var rule in StateService.BreakTimeRules)
                {
                    <div class="d-flex justify-content-between align-items-center mb-1 p-2 rounded transition-all" 
                         style="font-size: 0.8rem; background-color: var(--heritage-green-pale); border: 1px solid var(--border-color); color: var(--text-primary);">
                        <span class="fw-medium">@rule.DisplayText</span>
                        <button type="button" class="btn btn-sm btn-link p-0 text-danger" style="font-size: 0.8rem; line-height: 1;" @onclick="() => StateService.RemoveBreakTimeRule(rule.Id)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                              <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5"/>
                            </svg>
                        </button>
                    </div>
                }
            </div>
        </div>

        <hr style="border-top: 1px solid var(--border-color); opacity: 0.8;" />
        
        <h6 class="fw-semibold text-secondary mt-2 mb-3" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">최종 필터 (Final)</h6>
        
        <div class="form-check mb-2">
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" class="form-check-input m-0" id="idleTime" @bind="StateService.useIdleTimeFilter" style="cursor: pointer;">
                <label class="form-check-label" for="idleTime" style="cursor: pointer;">유휴시간 최소화 (최대 @StateService.maxIdleHours 시간)</label>
            </div>
        </div>
        <div class="ms-4 mb-2" style="display: @(StateService.useIdleTimeFilter ? "block" : "none")">
            <input type="number" class="form-control form-control-sm" @bind="StateService.maxIdleHours" min="1" max="5" />
        </div>

        <div class="form-check mb-2">
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" class="form-check-input m-0" id="maxDailyCourses" @bind="StateService.useMaxDailyCourses" style="cursor: pointer;">
                <label class="form-check-label" for="maxDailyCourses" style="cursor: pointer;">하루 최대 수업 수 (@StateService.maxCoursesPerDay 개)</label>
            </div>
        </div>
        <div class="ms-4 mb-2" style="display: @(StateService.useMaxDailyCourses ? "block" : "none")">
            <input type="number" class="form-control form-control-sm" @bind="StateService.maxCoursesPerDay" min="1" max="10" />
        </div>

        <div class="form-check mb-2">
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" class="form-check-input m-0" id="totalCredit" @bind="StateService.useTotalCreditFilter" style="cursor: pointer;">
                <label class="form-check-label" for="totalCredit" style="cursor: pointer;">총 학점 제한 (@StateService.minCredit ~ @StateService.maxCredit 학점)</label>
            </div>
        </div>
        <div class="ms-4 mb-2 row" style="display: @(StateService.useTotalCreditFilter ? "flex" : "none")">
            <div class="col-6">
                <input type="number" class="form-control form-control-sm" @bind="StateService.minCredit" min="0" />
            </div>
            <div class="col-6">
                <input type="number" class="form-control form-control-sm" @bind="StateService.maxCredit" min="@StateService.minCredit" />
            </div>
        </div>

        <button type="button" class="btn btn-primary mt-4 py-2 w-100 fw-bold transition-all" style="border-radius: 8px; box-shadow: 0 4px 12px rgba(18, 78, 63, 0.15);" @onclick="GenerateSchedules">
            @if (loading)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>생성하는 중...</span>
            }
            else
            {
                <span>시간표 생성</span>
            }
        </button>
    </div>
    <!-- 우측: 시간표 결과 패널 -->
    <div class="flex-grow-1">
        @if (StateService.generatedSchedules.Count == 0 && loading)
        {
            <p><em>시간표 생성 중...</em></p>
        }
        else if (StateService.generatedSchedules.Count == 0 && !loading)
        {
            <p><em>조건에 맞는 시간표가 없습니다.</em></p>
        }
        else
        {
        @foreach (var (schedule, idx) in StateService.generatedSchedules.Select((s, i) => (s, i + 1)))
        {
            var courseStartLookup = new Dictionary<(string day, int hour), (Course Course, CourseTime Time)>();
            var spannedSlots = new HashSet<(string day, int hour)>();
            var excludedSlots = new Dictionary<(string day, int hour), string>();

            if (StateService.useLunchBreak)
            {
                for (int h = 7; h <= 8; h++)
                {
                    foreach (var d in DaysOfWeek)
                    {
                        excludedSlots[(d, h)] = "점심공강";
                    }
                }
            }

            if (StateService.useNoDayFilter)
            {
                foreach (var day in StateService.NoDays)
                {
                    var dayStr = day.ToString();
                    for (int h = StartHour; h <= EndHour; h++)
                    {
                        excludedSlots[(dayStr, h)] = "요일공강";
                    }
                }
            }

            if (StateService.useBreakTimeFilter)
            {
                foreach (var rule in StateService.BreakTimeRules)
                {
                    var dayStr = rule.Day.ToString();
                    int startSlot = (rule.StartHour - 9) * 2 + 1;
                    int endSlot = (rule.EndHour - 9) * 2;
                    for (int h = startSlot; h <= endSlot; h++)
                    {
                        excludedSlots[(dayStr, h)] = "지정공강";
                    }
                }
            }

            foreach (var course in schedule)
            {
                foreach (var t in course.Times)
                {
                    var dayStr = t.day.ToString();
                    courseStartLookup[(dayStr, t.start)] = (course, t);
                    
                    for (int h = t.start + 1; h <= t.end; h++)
                    {
                        spannedSlots.Add((dayStr, h));
                    }
                }
            }

            <div class="card my-4 p-4 border-0" style="border-radius: 16px; box-shadow: var(--card-shadow); background-color: var(--surface-white);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0" style="color: var(--heritage-green); letter-spacing: -0.5px;">시간표 @idx</h5>
                    @{
                        var isSelected = StateService.IsScheduleSelected(schedule);
                        <button type="button" class="btn btn-sm px-3 py-1.5 rounded-pill transition-all text-nowrap fw-semibold border-0"
                                style="font-size: 0.8rem;
                                       background-color: @(isSelected ? "var(--heritage-green)" : "var(--heritage-green-pale)");
                                       color: @(isSelected ? "var(--possibility-white)" : "var(--text-primary)");
                                       box-shadow: 0 2px 5px rgba(0,0,0,0.05);"
                                @onclick="@(_ => StateService.ToggleSelectSchedule(schedule))">
                            @if (isSelected)
                            {
                                <span>내 시간표에 담김 ✓</span>
                            }
                            else
                            {
                                <span>선택하기 +</span>
                            }
                        </button>
                    }
                </div>
                <table class="table text-center align-middle" style="width: 100%; table-layout: fixed; border-collapse: separate; border-spacing: 4px; border: none; margin-bottom: 0;">
                    <thead>
                        <tr style="background-color: var(--heritage-green-pale); color: var(--heritage-green);">
                            <th style="width: 85px; font-weight: 600; border: none; border-radius: 8px 0 0 8px; padding: 10px 0;">시간</th>
                            @foreach (var day in DaysOfWeek)
                            {
                                var isLast = day == DaysOfWeek[^1];
                                <th style="font-weight: 600; border: none; @(isLast ? "border-radius: 0 8px 8px 0;" : "") padding: 10px 0;">@day</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var currentEndHour = GetMaxEndHour(schedule);
                        }
                        @for (int hour = StartHour; hour <= currentEndHour; hour++)
                        {
                            <tr>
                                @{
                                    var totalMinutes = 9 * 60 + (hour - 1) * 30;
                                    var displayHour = totalMinutes / 60;
                                    var displayMinute = totalMinutes % 60;
                                }
                                <td style="font-weight: 500; font-size: 0.8rem; color: var(--text-secondary); background-color: var(--possibility-white); border: 1px solid var(--border-color); border-radius: 8px; padding: 6px 0;">
                                    @($"{displayHour:D2}:{displayMinute:D2}")
                                </td>
                                @foreach (var day in DaysOfWeek)
                                {
                                    if (courseStartLookup.TryGetValue((day, hour), out var slot))
                                    {
                                        var color = GetCourseColor(slot.Course.Name);
                                        <td rowspan="@(slot.Time.end - slot.Time.start + 1)" 
                                            @onclick="@(_ => ShowCourseDetail(slot.Course))"
                                            style="background-color:@color; color:#0e201c; font-weight:600; border-radius: 8px; border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.05); font-size: 0.85rem; padding: 8px; cursor: pointer;"
                                            class="course-cell-hover">
                                            <div class="fw-bold text-truncate" title="@slot.Course.Name">@slot.Course.Name</div>
                                            <div class="text-truncate" style="font-size: 0.72rem; opacity: 0.85; margin-top: 2px;">@slot.Course.Professor</div>
                                            <div style="font-size: 0.68rem; opacity: 0.75; margin-top: 2px; font-family: monospace;">@slot.Course.ClassNumber</div>
                                        </td>
                                    }
                                    else if (spannedSlots.Contains((day, hour)))
                                    {
                                        // 이미 위에서 렌더링된 셀에 포함되었으므로, 현재 <td>는 렌더링하지 않음
                                    }
                                    else if (excludedSlots.TryGetValue((day, hour), out var reason))
                                    {
                                        <td style="background-color: #F2F7F5; color: #839E98; font-size: 0.72rem; font-weight: 500; border-radius: 8px; border: 1px dashed var(--border-color); padding: 4px;">
                                            @reason
                                        </td>
                                    }
                                    else
                                    {
                                        <td style="background-color: transparent; border: 1px solid rgba(211, 226, 221, 0.4); border-radius: 8px; padding: 0;"></td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        }
    </div>
</div>

@if (selectedCourseForModal != null)
{
    <div class="custom-modal-backdrop" @onclick="CloseModal">
        <div class="custom-modal-content" @onclick:stopPropagation>
            <div class="custom-modal-header" style="background-color: var(--heritage-green); color: var(--possibility-white);">
                <h6 class="fw-bold mb-0">강의 상세 정보</h6>
                <button type="button" class="btn-close btn-close-white" @onclick="CloseModal" style="font-size: 0.75rem;" aria-label="Close"></button>
            </div>
            <div class="custom-modal-body p-4 text-start">
                <h4 class="fw-bold mb-1" style="color: var(--heritage-green); font-size: 1.3rem;">@selectedCourseForModal.Name</h4>
                <span class="badge px-2.5 py-1 rounded-pill mb-3" style="background-color: var(--heritage-green-pale); color: var(--heritage-green); font-size: 0.75rem;">
                    @selectedCourseForModal.Division
                </span>
                
                <div class="row g-3" style="font-size: 0.85rem;">
                    <div class="col-6">
                        <span class="text-secondary small d-block">담당교수</span>
                        <span class="fw-semibold text-dark">@selectedCourseForModal.Professor</span>
                    </div>
                    <div class="col-6">
                        <span class="text-secondary small d-block">과목번호</span>
                        <span class="fw-semibold text-dark font-monospace">@selectedCourseForModal.ClassNumber</span>
                    </div>
                    <div class="col-6">
                        <span class="text-secondary small d-block">학수번호</span>
                        <span class="fw-semibold text-dark font-monospace">@selectedCourseForModal.CourseID</span>
                    </div>
                    <div class="col-6">
                        <span class="text-secondary small d-block">교과번호</span>
                        <span class="fw-semibold text-dark font-monospace">@selectedCourseForModal.CourseNumber</span>
                    </div>
                    <div class="col-6">
                        <span class="text-secondary small d-block">대상학년</span>
                        <span class="fw-semibold text-dark">@(selectedCourseForModal.Grade)학년</span>
                    </div>
                    <div class="col-6">
                        <span class="text-secondary small d-block">학점</span>
                        <span class="fw-semibold text-dark">@(selectedCourseForModal.Credit)학점</span>
                    </div>
                    <div class="col-12">
                        <span class="text-secondary small d-block">시간 및 강의실</span>
                        @if (selectedCourseForModal.Times != null && selectedCourseForModal.Times.Count > 0)
                        {
                            @foreach (var t in selectedCourseForModal.Times)
                            {
                                <span class="fw-semibold text-dark d-block">@GetFormattedCourseTime(t)</span>
                            }
                        }
                        else
                        {
                            <span class="fw-semibold text-dark">정보 없음</span>
                        }
                    </div>
                </div>
            </div>
            <div class="custom-modal-footer p-3 border-top text-end">
                <button type="button" class="btn px-4 py-1.5 rounded-pill fw-semibold border-0 text-white transition-all" 
                        style="background-color: var(--heritage-green); font-size: 0.85rem;"
                        @onclick="CloseModal">닫기</button>
            </div>
        </div>
    </div>
}


@code {
    

    private static readonly string[] DaysOfWeek = { "월", "화", "수", "목", "금", "토" };
    private const int StartHour = 1;
    private const int EndHour = 18; // 기본 최대 시간 18:00 (슬롯 18)
    private bool loading = false;
    


    // 랜덤 색상 저장용
    private Dictionary<string, string> courseColors = new();
    private Course? selectedCourseForModal;

    private void ShowCourseDetail(Course course)
    {
        selectedCourseForModal = course;
    }

    private void CloseModal()
    {
        selectedCourseForModal = null;
    }

    private string GetFormattedCourseTime(CourseTime t)
    {
        var dayStr = t.day switch
        {
            WebASMTimeTabler.Core.DayOfWeek.월 => "월",
            WebASMTimeTabler.Core.DayOfWeek.화 => "화",
            WebASMTimeTabler.Core.DayOfWeek.수 => "수",
            WebASMTimeTabler.Core.DayOfWeek.목 => "목",
            WebASMTimeTabler.Core.DayOfWeek.금 => "금",
            WebASMTimeTabler.Core.DayOfWeek.토 => "토",
            WebASMTimeTabler.Core.DayOfWeek.일 => "일",
            WebASMTimeTabler.Core.DayOfWeek.e러닝 => "e러닝",
            _ => "알수없음"
        };

        if (t.day == WebASMTimeTabler.Core.DayOfWeek.e러닝)
        {
            return "e러닝 (원격강의)";
        }

        var startMin = 9 * 60 + (t.start - 1) * 30;
        var endMin = 9 * 60 + (t.end - 1) * 30 + 30;

        var startHourStr = $"{startMin / 60:D2}:{startMin % 60:D2}";
        var endHourStr = $"{endMin / 60:D2}:{endMin % 60:D2}";

        var roomStr = string.IsNullOrWhiteSpace(t.Room) ? "강의실 미지정" : t.Room;

        return $"{dayStr}요일 {startHourStr}~{endHourStr} ({roomStr})";
    }

    private string GetCourseColor(string courseName)
    {
        if (!courseColors.ContainsKey(courseName))
        {
            var rand = new Random(courseName.GetHashCode());
            var hue = rand.Next(0, 360);
            courseColors[courseName] = $"hsl({hue}, 40%, 85%)"; // 눈이 아프지 않고 가독성 높은 부드러운 파스텔 톤
        }
        return courseColors[courseName];
    }

    private int GetMaxEndHour(List<Course> schedule)
    {
        int maxHour = 18; // 기본 18:00 종료 (슬롯 18)
        foreach (var course in schedule)
        {
            if (course.Times == null) continue;
            foreach (var t in course.Times)
            {
                if (t.end > maxHour)
                {
                    maxHour = t.end;
                }
            }
        }
        return maxHour;
    }
    private void AddBreakRule()
    {
        StateService.AddBreakTimeRule(StateService.tempBreakTimeDay, StateService.tempBreakTimeStartHour, StateService.tempBreakTimeEndHour);
    }
    private async Task GenerateSchedules()
    {
        Console.WriteLine($"선택된 그룹 수: {StateService.GroupedCourses.Count}");
        foreach(var group in StateService.GroupedCourses) {
            Console.WriteLine($"그룹: {group[0].Name}, 분반 수: {group.Count}");
        }
        loading = true;
        StateService.generatedSchedules.Clear();
        StateHasChanged(); // "생성 중..." 메시지를 즉시 표시하기 위해 호출

        var selectedCourses = StateService.SelectedCourses.ToList();
        // 필터 목록 구성
        StateService.RealtimeFilters.Clear();
        StateService.RealtimeFilters.Add(new TimeConflictFilter());
        StateService.FinalFilters.Clear();
        
        if (StateService.useLunchBreak) StateService.RealtimeFilters.Add(new LunchBreakFilter());
        if (StateService.useMorningFilter) StateService.RealtimeFilters.Add(new MorningFilter());
        if (StateService.useNoDayFilter)
        {
            foreach (var day in StateService.NoDays)
            {
                StateService.RealtimeFilters.Add(new NoDayFilter(day));
            }
        }
        
        if (StateService.useMaxConsecutive) StateService.RealtimeFilters.Add(new MaxConsecutiveFilter(StateService.maxConsecutiveHours));
        if (StateService.useBreakTimeFilter)
        {
            foreach (var rule in StateService.BreakTimeRules)
            {
                int startSlot = (rule.StartHour - 9) * 2 + 1;
                int endSlot = (rule.EndHour - 9) * 2;
                StateService.RealtimeFilters.Add(new BreakTimeFilter(rule.Day, (startSlot, endSlot)));
            }
        }

        if (StateService.useIdleTimeFilter) StateService.FinalFilters.Add(new IdleTimeFilter(StateService.maxIdleHours));
        if (StateService.useMaxDailyCourses) StateService.FinalFilters.Add(new MaxDailyCoursesFilter(StateService.maxCoursesPerDay));
        if (StateService.useTotalCreditFilter) StateService.FinalFilters.Add(new TotalCreditFilter(StateService.minCredit, StateService.maxCredit));


        var service = new ScheduleService(
            maxPages: 50,
            realtimeFilters: StateService.RealtimeFilters,
            finalFilters: StateService.FinalFilters
        );

        // IAsyncEnumerable을 직접 순회합니다.
        await foreach (var schedule in service.GenerateSchedulesAsync(StateService.GroupedCourses))
        {
            StateService.generatedSchedules.Add(schedule);
            StateHasChanged(); // 결과가 나올 때마다 UI를 갱신

            // ✅ 핵심: UI 스레드에 제어권을 잠시 넘겨줘서 멈춤 현상을 방지합니다.
            await Task.Delay(1);
        }

        // 모든 작업이 끝난 후 loading 상태를 변경합니다.
        //Console.WriteLine($"총 {generatedSchedules.Count}개의 시간표 생성됨."); // deguging
        loading = false;
        StateHasChanged();
    }
}