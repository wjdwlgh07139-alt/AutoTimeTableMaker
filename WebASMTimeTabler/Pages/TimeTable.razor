@page "/timetable"
@using WebASMTimeTabler.Core
@using CoreDay = WebASMTimeTabler.Core.DayOfWeek
@inject ScheduleStateService StateService
@inject NavigationManager NavManager

<PageTitle>시간표 - Timeship</PageTitle>

<!-- 모바일 전용 정적 타이틀 및 설명 -->
<div class="d-block d-md-none mb-3 px-2">
    <h4 class="fw-bold mb-1" style="color: var(--heritage-green); letter-spacing: -0.5px; font-size: 1.35rem;">시간표 확인</h4>
    <p class="text-secondary small mb-0" style="font-size: 0.82rem;">
        아래로 스크롤하며 생성된 조합들을 비교하고 <strong>'선택하기'</strong>를 눌러 담아보세요.
    </p>
</div>

<div class="d-flex gap-4 align-items-start" style="padding-bottom: 7.5rem !important;">
    <!-- 데스크탑 뷰: 좌측 필터 설정 사이드바 (모바일에서는 d-none d-md-block 으로 숨김) -->
    <div class="card p-4 flex-shrink-0 border-0 d-none d-md-block"
         style="width: 340px; border-radius: 16px; background-color: var(--surface-white); box-shadow: var(--card-shadow); font-size: 0.95rem; position: sticky; top: 5rem; z-index: 10;">
        <h5 class="fw-bold mb-3" style="color: var(--heritage-green); letter-spacing: -0.5px;">필터 설정</h5>

        <h6 class="fw-semibold text-secondary mt-2 mb-3"
            style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">실시간 필터 (Realtime)</h6>

        <div class="form-check mb-2 d-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input m-0" id="lunchBreak" @bind="StateService.useLunchBreak"
                   style="cursor: pointer;">
            <label class="form-check-label" for="lunchBreak" style="cursor: pointer;">점심시간 공강 (12:00-13:00)</label>
        </div>

        <div class="form-check mb-2 d-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input m-0" id="morningFilter" @bind="StateService.useMorningFilter"
                   style="cursor: pointer;">
            <label class="form-check-label" for="morningFilter" style="cursor: pointer;">아침 수업 금지 (10시 이전)</label>
        </div>

        <div class="form-check mb-2 d-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input m-0" id="noDayFilter" @bind="StateService.useNoDayFilter"
                   style="cursor: pointer;">
            <label class="form-check-label" for="noDayFilter" style="cursor: pointer;">특정 요일 공강</label>
        </div>
        @if (StateService.useNoDayFilter)
        {
            <div class="ms-1 my-2 d-flex gap-1 flex-wrap">
                @foreach (var day in Enum.GetValues<CoreDay>().Where(d => d >= CoreDay.월 && d <= CoreDay.토))
                {
                    var isChecked = StateService.NoDays.Contains(day);
                    <button type="button" class="btn btn-sm px-2 py-1 rounded-pill border-0 transition-all text-nowrap" style="font-size: 0.8rem;
                        background-color: @(isChecked ? "var(--heritage-green)" : "var(--heritage-green-pale)");
                        color: @(isChecked ? "var(--possibility-white)" : "var(--text-primary)");
                        font-weight: 500;" @onclick="@(_ => StateService.ToggleNoDay(day))">
                        @day.ToString()
                    </button>
                }
            </div>
        }

        <div class="form-check mb-2">
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" class="form-check-input m-0" id="maxConsecutive"
                       @bind="StateService.useMaxConsecutive" style="cursor: pointer;">
                <label class="form-check-label" for="maxConsecutive" style="cursor: pointer;">연강 제한 (최대
                    @StateService.maxConsecutiveHours 시간)</label>
                </div>
            </div>
            <div class="ms-4 mb-2" style="display: @(StateService.useMaxConsecutive ? "block" : "none")">
                <input type="number" class="form-control form-control-sm" @bind="StateService.maxConsecutiveHours" min="1"
                       max="5" />
            </div>

            <div class="form-check mb-2">
                <div class="d-flex align-items-center gap-2">
                    <input type="checkbox" class="form-check-input m-0" id="useBreakTime"
                           @bind="StateService.useBreakTimeFilter" style="cursor: pointer;">
                    <label class="form-check-label" for="useBreakTime" style="cursor: pointer;">지정시간 비우기</label>
                </div>
            </div>
            <div class="ms-4 mb-2 p-2.5 rounded-3 bg-light border"
                 style="display: @(StateService.useBreakTimeFilter ? "block" : "none"); font-size: 0.82rem;">
                <div class="row g-2 mb-2">
                    <div class="col-12">
                        <select class="form-select form-select-sm" @bind="StateService.tempBreakTimeDay">
                            @foreach (var day in Enum.GetValues<CoreDay>().Where(d => d >= CoreDay.월 && d <= CoreDay.토))
                            {
                                <option value="@day">@day.ToString()요일</option>
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="small text-secondary">시작</label>
                        <select class="form-select form-select-sm" @bind="StateService.tempBreakTimeStartHour">
                            @for (int h = 9; h <= 18; h++)
                            {
                                <option value="@h">@($"{h:D2}:00")</option>
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="small text-secondary">종료</label>
                        <select class="form-select form-select-sm" @bind="StateService.tempBreakTimeEndHour">
                            @for (int h = 10; h <= 18; h++)
                            {
                                <option value="@h">@($"{h:D2}:00")</option>
                            }
                        </select>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-success w-100 fw-semibold mb-2" @onclick="AddBreakRule">규칙 추가</button>
                <div class="d-flex flex-column gap-1 max-vh-20 overflow-y-auto">
                    @foreach (var rule in StateService.BreakTimeRules)
                    {
                        <div class="d-flex justify-content-between align-items-center bg-white p-1.5 rounded border"
                             style="font-size: 0.78rem;">
                            <span>@($"{rule.Day.ToString()} {rule.StartHour:D2}:00~{rule.EndHour:D2}:00")</span>
                            <button type="button" class="btn btn-sm btn-link p-0 text-danger"
                                    style="font-size: 0.8rem; line-height: 1;
                                    " @onclick="() => StateService.RemoveBreakTimeRule(rule.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                     class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                    <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            </div>

            <hr style="border-top: 1px solid var(--border-color); opacity: 0.8;" />

            <h6 class="fw-semibold text-secondary mt-2 mb-3"
                style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">최종 필터 (Final)</h6>

            <div class="form-check mb-2">
                <div class="d-flex align-items-center gap-2">
                    <input type="checkbox" class="form-check-input m-0" id="idleTime" @bind="StateService.useIdleTimeFilter"
                           style="cursor: pointer;">
                    <label class="form-check-label" for="idleTime" style="cursor: pointer;">유휴시간 최소화 (최대
                        @StateService.maxIdleHours 시간)</label>
                    </div>
                </div>
                <div class="ms-4 mb-2" style="display: @(StateService.useIdleTimeFilter ? "block" : "none")">
                    <input type="number" class="form-control form-control-sm" @bind="StateService.maxIdleHours" min="1"
                           max="5" />
                </div>

                <div class="form-check mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <input type="checkbox" class="form-check-input m-0" id="maxDailyCourses"
                               @bind="StateService.useMaxDailyCourses" style="cursor: pointer;">
                        <label class="form-check-label" for="maxDailyCourses" style="cursor: pointer;">하루 최대 수업 수
                            (@StateService.maxCoursesPerDay 개)</label>
                        </div>
                    </div>
                    <div class="ms-4 mb-2" style="display: @(StateService.useMaxDailyCourses ? "block" : "none")">
                        <input type="number" class="form-control form-control-sm" @bind="StateService.maxCoursesPerDay" min="1"
                               max="10" />
                    </div>

                    <div class="form-check mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <input type="checkbox" class="form-check-input m-0" id="totalCredit"
                                   @bind="StateService.useTotalCreditFilter" style="cursor: pointer;">
                            <label class="form-check-label" for="totalCredit" style="cursor: pointer;">총 학점 제한
                                (@StateService.minCredit ~ @StateService.maxCredit 학점)</label>
                            </div>
                        </div>
                        <div class="ms-4 mb-2 row" style="display: @(StateService.useTotalCreditFilter ? "flex" : "none")">
                            <div class="col-6">
                                <input type="number" class="form-control form-control-sm" @bind="StateService.minCredit" min="0" />
                            </div>
                            <div class="col-6">
                                <input type="number" class="form-control form-control-sm" @bind="StateService.maxCredit"
                                       min="@StateService.minCredit" />
                            </div>
                        </div>

                        <button type="button" class="btn btn-primary mt-4 py-2 w-100 fw-bold transition-all"
                                style="border-radius: 8px; box-shadow: 0 4px 12px rgba(18, 78, 63, 0.15);" @onclick="GenerateSchedules">
                            @if (loading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>생성하는 중...</span>
                            }
                            else
                            {
                                <span>시간표 생성</span>
                            }
                        </button>
                    </div>

                    <!-- 우측: 시간표 결과 패널 (데스크탑과 모바일 공통 세로 스크롤형 카드 레이아웃) -->
                    <div class="flex-grow-1">
                        @if (StateService.generatedSchedules.Count == 0 && loading)
                        {
                            <p><em>시간표 생성 중...</em></p>
                        }
                        else if (StateService.generatedSchedules.Count == 0 && !loading)
                        {
                            <p><em>조건에 맞는 시간표가 없습니다.</em></p>
                        }
                        else
                        {
                            @foreach (var (schedule, idx) in StateService.generatedSchedules.Select((s, i) => (s, i + 1)))
                            {
                                var activeDays = DaysOfWeek.ToList();
                                bool hasSat = schedule.Any(c => c.Times != null && c.Times.Any(t => t.day == WebASMTimeTabler.Core.DayOfWeek.토));
                                if (!hasSat)
                                {
                                    activeDays.Remove("토");
                                }

                                var courseStartLookup = new Dictionary<(string day, int hour), (Course Course, CourseTime Time)>();
                                var spannedSlots = new HashSet<(string day, int hour)>();
                                var excludedSlots = new Dictionary<(string day, int hour), string>();

                                // 필터링 조건 시각화 정보 수집
                                if (StateService.useLunchBreak)
                                {
                                    foreach (var day in activeDays)
                                    {
                                        excludedSlots[(day, 7)] = "점심";
                                        excludedSlots[(day, 8)] = "점심";
                                    }
                                }
                                if (StateService.useMorningFilter)
                                {
                                    foreach (var day in activeDays)
                                    {
                                        excludedSlots[(day, 1)] = "아침";
                                        excludedSlots[(day, 2)] = "아침";
                                    }
                                }
                                if (StateService.useNoDayFilter)
                                {
                                    foreach (var day in StateService.NoDays)
                                    {
                                        var dayStr = day.ToString();
                                        for (int h = StartHour; h <= EndHour; h++)
                                        {
                                            excludedSlots[(dayStr, h)] = "지정공강";
                                        }
                                    }
                                }
                                if (StateService.useBreakTimeFilter)
                                {
                                    foreach (var rule in StateService.BreakTimeRules)
                                    {
                                        var dayStr = rule.Day.ToString();
                                        int startSlot = (rule.StartHour - 9) * 2 + 1;
                                        int endSlot = (rule.EndHour - 9) * 2;
                                        for (int h = startSlot; h <= endSlot; h++)
                                        {
                                            excludedSlots[(dayStr, h)] = "지정공강";
                                        }
                                    }
                                }

                                // 시간표에 속한 고유 과목명 목록 추출 및 정렬하여 색상 겹침 100% 방지
                                var distinctCourseNames = schedule.Select(c => c.Name).Distinct().OrderBy(name => name).ToList();
                                var localColors = new Dictionary<string, string>();
                                var palette = new[]
                                {
                                    "hsl(200, 85%, 90%)",  // sky blue
                                    "hsl(340, 85%, 90%)",  // rose pink
                                    "hsl(140, 75%, 90%)",  // mint green
                                    "hsl(28, 85%, 88%)",   // apricot orange
                                    "hsl(270, 80%, 90%)",  // lavender purple
                                    "hsl(50, 85%, 88%)",   // lemon yellow
                                    "hsl(175, 75%, 88%)",  // soft teal
                                    "hsl(300, 70%, 90%)",  // mauve pink
                                    "hsl(10, 80%, 90%)",   // coral pink
                                    "hsl(90, 65%, 88%)",   // sage green
                                    "hsl(220, 80%, 90%)",  // ocean blue
                                    "hsl(15, 60%, 90%)"    // mocha rose
                                };
                                for (int k = 0; k < distinctCourseNames.Count; k++)
                                {
                                    localColors[distinctCourseNames[k]] = palette[k % palette.Length];
                                }

                                foreach (var course in schedule)
                                {
                                    foreach (var t in course.Times)
                                    {
                                        var dayStr = t.day.ToString();
                                        courseStartLookup[(dayStr, t.start)] = (course, t);

                                        for (int h = t.start + 1; h <= t.end; h++)
                                        {
                                            spannedSlots.Add((dayStr, h));
                                        }
                                    }
                                }

                                <div class="card my-3 p-1 p-md-4 border-0" style="border-radius: 12px; box-shadow: var(--card-shadow); background-color: var(--surface-white);">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="fw-bold mb-0" style="color: var(--heritage-green); letter-spacing: -0.5px;">시간표 @idx</h5>
                                        @{
                                            var isSelected = StateService.IsScheduleSelected(schedule);
                                            <button type="button"
                                                    class="btn btn-sm px-3 py-1.5 rounded-pill transition-all text-nowrap fw-semibold border-0" style="font-size: 0.8rem;
                                                background-color: @(isSelected ? "var(--heritage-green)" : "var(--heritage-green-pale)");
                                                color: @(isSelected ? "var(--possibility-white)" : "var(--text-primary)");
                                                box-shadow: 0 2px 5px rgba(0,0,0,0.05);"
                                                    @onclick="@(_ => StateService.ToggleSelectSchedule(schedule))">
                                                @if (isSelected)
                                                {
                                                    <span>내 시간표에 담김 ✓</span>
                                                }
                                                else
                                                {
                                                    <span>선택하기 +</span>
                                                }
                                            </button>
                                        }
                                    </div>
                                    <div class="table-responsive" style="margin: 0; padding: 0;">
                                        <table class="table text-center align-middle" style="width: 100%; table-layout: fixed; border-collapse: separate; border-spacing: 1.5px; background-color: #e2e8f0; border: none; margin-bottom: 0;">
                                            <thead>
                                                <tr style="background-color: #f8fafc; color: #334155; font-size: 0.8rem;">
                                                    <th style="width: 26px; font-weight: 600; border: none; padding: 6px 0;"></th>
                                                    @foreach (var day in activeDays)
                                                    {
                                                        <th style="font-weight: 600; border: none; padding: 6px 0;">@day</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @{
                                                    var currentEndHour = GetMaxEndHour(schedule);
                                                }
                                                @for (int hour = StartHour; hour <= currentEndHour; hour++)
                                                {
                                                    <tr style="height: 28px;">
                                                        @if (hour % 2 == 1)
                                                        {
                                                            var totalMinutes = 9 * 60 + (hour - 1) * 30;
                                                            var displayHour = totalMinutes / 60;
                                                            <td rowspan="2" style="font-weight: 600; font-size: 0.8rem; color: #64748b; background-color: #f8fafc; border: none; padding: 0; width: 26px; text-align: center; vertical-align: middle;">
                                                                @displayHour
                                                            </td>
                                                        }
                                                        @foreach (var day in activeDays)
                                                        {
                                                            if (courseStartLookup.TryGetValue((day, hour), out var slot))
                                                            {
                                                                var color = localColors.TryGetValue(slot.Course.Name, out var cCol) ? cCol : GetCourseColor(slot.Course.Name);
                                                                <td rowspan="@(slot.Time.end - slot.Time.start + 1)" 
                                                                    @onclick="@(_ => ShowCourseDetail(slot.Course))"
                                                                    style="background-color:@color; color:#1e293b; font-weight:bold; border-radius: 0px; border: none; font-size: 0.78rem; padding: 5px; text-align: left; vertical-align: top; cursor: pointer; line-height: 1.25;"
                                                                    class="course-cell-hover">
                                                                    <div class="fw-bold" style="color: #1e293b;">@slot.Course.Name</div>
                                                                    @if (!string.IsNullOrWhiteSpace(slot.Time.Room))
                                                                    {
                                                                        <div style="font-size: 0.65rem; color: #64748b; margin-top: 3px; font-weight: 500;">@slot.Time.Room</div>
                                                                    }
                                                                </td>
                                                            }
                                                            else if (spannedSlots.Contains((day, hour)))
                                                            {
                                                                // 이미 위에서 렌더링된 셀에 포함되었으므로, 현재 <td>는 렌더링하지 않음
                                                            }
                                                            else if (excludedSlots.TryGetValue((day, hour), out var reason))
                                                            {
                                                                <td style="background-color: #f1f5f9; color: #94a3b8; font-size: 0.7rem; font-weight: 500; border: none; padding: 4px;">
                                                                    @reason
                                                                </td>
                                                            }
                                                            else
                                                            {
                                                                <td style="background-color: #ffffff; border: none; padding: 0;"></td>
                                                            }
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- 모바일 전용 통합 플로팅 네비게이션 & 필터 바 -->
                <div class="d-block d-md-none position-fixed" style="bottom: 1.5rem; left: 50%; transform: translateX(-50%); z-index: 1000; width: 92%; max-width: 380px;">
                    <div class="d-flex bg-white shadow-lg border rounded-pill p-1 align-items-center justify-content-between" style="box-shadow: 0 8px 30px rgba(0,0,0,0.12) !important;">
                        <button type="button" class="btn btn-sm border-0 rounded-pill fw-bold px-3 py-2 text-nowrap" 
                                style="font-size: 0.78rem; transition: all 0.2s; color: var(--heritage-green); background: transparent;" @onclick="GoToCourses">
                            📝 과목 선택
                        </button>
                        <div style="width: 1px; height: 16px; background-color: #dee2e6;"></div>
                        <button type="button" class="btn btn-sm border-0 rounded-pill fw-bold px-3 py-2 text-nowrap" 
                                style="font-size: 0.78rem; transition: all 0.2s; color: var(--heritage-green); background: transparent;" @onclick="GoToMySchedules">
                            🗃️ 내 시간표
                        </button>
                        <div style="width: 1px; height: 16px; background-color: #dee2e6;"></div>
                        <button type="button" class="btn btn-sm rounded-pill fw-bold px-3 py-2 text-nowrap" 
                                style="font-size: 0.78rem; transition: all 0.2s; background-color: var(--heritage-green); color: white; border: none; box-shadow: 0 2px 6px rgba(18, 78, 63, 0.2);" @onclick="ToggleMobileFilter">
                            ⚙️ 필터 설정
                        </button>
                    </div>
                </div>

                <!-- 모바일 전용 필터 모달 팝업 -->
                @if (showMobileFilterModal)
                {
                    <div class="custom-modal-backdrop" @onclick="ToggleMobileFilter"
                         style="z-index: 1050; display: flex; align-items: center; justify-content: center; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(0,0,0,0.5);">
                        <div class="custom-modal-content p-4" @onclick:stopPropagation
                             style="max-height: 85vh; overflow-y: auto; width: 90%; max-width: 400px; border-radius: 20px; background-color: white; box-shadow: 0 10px 40px rgba(0,0,0,0.2);">
                            <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                                <h5 class="fw-bold mb-0" style="color: var(--heritage-green);">필터 설정</h5>
                                <button type="button" class="btn-close" @onclick="ToggleMobileFilter" aria-label="Close"
                                        style="border: none; background: transparent; font-size: 1.5rem; line-height: 1; padding: 0;">&times;</button>
                            </div>

                            <h6 class="fw-semibold text-secondary mt-2 mb-3"
                                style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">실시간 필터 (Realtime)</h6>

                            <div class="form-check mb-2 d-flex align-items-center gap-2">
                                <input type="checkbox" class="form-check-input m-0" id="mobileLunchBreak" @bind="StateService.useLunchBreak"
                                       style="cursor: pointer;">
                                <label class="form-check-label" for="mobileLunchBreak" style="cursor: pointer;">점심시간 공강 (12:00-13:00)</label>
                            </div>

                            <div class="form-check mb-2 d-flex align-items-center gap-2">
                                <input type="checkbox" class="form-check-input m-0" id="mobileMorningFilter" @bind="StateService.useMorningFilter"
                                       style="cursor: pointer;">
