@code {
    protected override async Task OnInitializedAsync()
    {
        if (StateService.autoGenerateOnLoad)
        {
            StateService.autoGenerateOnLoad = false;
            if (StateService.GroupedCourses.Count > 0)
            {
                await GenerateSchedules();
            }
        }
    }

    private bool showMobileFilterModal = false;
    private void ToggleMobileFilter() => showMobileFilterModal = !showMobileFilterModal;
    private async Task ApplyMobileFiltersAndClose()
    {
        showMobileFilterModal = false;
        await GenerateSchedules();
    }

    private static readonly string[] DaysOfWeek = { "월", "화", "수", "목", "금", "토" };
    private const int StartHour = 1;
    private const int EndHour = 18; // 기본 최대 시간 18:00 (슬롯 18)
    private bool loading = false;

    // 랜덤 색상 저장용
    private Dictionary<string, string> courseColors = new();
    private Course? selectedCourseForModal;

    private void ShowCourseDetail(Course course)
    {
        selectedCourseForModal = course;
    }

    private void CloseModal()
    {
        selectedCourseForModal = null;
    }

    private string GetFormattedCourseTime(CourseTime t)
    {
        var dayStr = t.day switch
        {
            WebASMTimeTabler.Core.DayOfWeek.월 => "월",
            WebASMTimeTabler.Core.DayOfWeek.화 => "화",
            WebASMTimeTabler.Core.DayOfWeek.수 => "수",
            WebASMTimeTabler.Core.DayOfWeek.목 => "목",
            WebASMTimeTabler.Core.DayOfWeek.금 => "금",
            WebASMTimeTabler.Core.DayOfWeek.토 => "토",
            WebASMTimeTabler.Core.DayOfWeek.일 => "일",
            WebASMTimeTabler.Core.DayOfWeek.e러닝 => "e러닝",
            _ => "알수없음"
        };

        if (t.day == WebASMTimeTabler.Core.DayOfWeek.e러닝)
        {
            return "e러닝 (원격강의)";
        }

        var startMin = 9 * 60 + (t.start - 1) * 30;
        var endMin = 9 * 60 + (t.end - 1) * 30 + 30;

        var startHourStr = $"{startMin / 60:D2}:{startMin % 60:D2}";
        var endHourStr = $"{endMin / 60:D2}:{endMin % 60:D2}";

        var roomStr = string.IsNullOrWhiteSpace(t.Room) ? "강의실 미지정" : t.Room;

        return $"{dayStr}요일 {startHourStr}~{endHourStr} ({roomStr})";
    }

    private string GetCourseColor(string courseName)
    {
        if (!courseColors.ContainsKey(courseName))
        {
            var rand = new Random(courseName.GetHashCode());
            var hue = rand.Next(0, 360);
            courseColors[courseName] = $"hsl({hue}, 40%, 85%)"; // 눈이 아프지 않고 가독성 높은 부드러운 파스텔 톤
        }
        return courseColors[courseName];
    }

    private int GetMaxEndHour(List<Course> schedule)
    {
        int maxHour = 18; // 기본 18:00 종료 (슬롯 18)
        foreach (var course in schedule)
        {
            if (course.Times == null) continue;
            foreach (var t in course.Times)
            {
                if (t.end > maxHour)
                {
                    maxHour = t.end;
                }
            }
        }
        return maxHour;
    }

    private void AddBreakRule()
    {
        StateService.AddBreakTimeRule(StateService.tempBreakTimeDay, StateService.tempBreakTimeStartHour, StateService.tempBreakTimeEndHour);
    }

    private async Task GenerateSchedules()
    {
        Console.WriteLine($"선택된 그룹 수: {StateService.GroupedCourses.Count}");
        foreach (var group in StateService.GroupedCourses)
        {
            Console.WriteLine($"그룹: {group[0].Name}, 분반 수: {group.Count}");
        }
        loading = true;
        StateService.generatedSchedules.Clear();
        StateHasChanged(); // "생성 중..." 메시지를 즉시 표시하기 위해 호출

        var selectedCourses = StateService.SelectedCourses.ToList();
        // 필터 목록 구성
        StateService.RealtimeFilters.Clear();
        StateService.RealtimeFilters.Add(new TimeConflictFilter());
        StateService.FinalFilters.Clear();

        if (StateService.useLunchBreak) StateService.RealtimeFilters.Add(new LunchBreakFilter());
        if (StateService.useMorningFilter) StateService.RealtimeFilters.Add(new MorningFilter());
        if (StateService.useNoDayFilter)
        {
            foreach (var day in StateService.NoDays)
            {
                StateService.RealtimeFilters.Add(new NoDayFilter(day));
            }
        }

        if (StateService.useMaxConsecutive) StateService.RealtimeFilters.Add(new MaxConsecutiveFilter(StateService.maxConsecutiveHours));
        if (StateService.useBreakTimeFilter)
        {
            foreach (var rule in StateService.BreakTimeRules)
            {
                int startSlot = (rule.StartHour - 9) * 2 + 1;
                int endSlot = (rule.EndHour - 9) * 2;
                StateService.RealtimeFilters.Add(new BreakTimeFilter(rule.Day, (startSlot, endSlot)));
            }
        }

        if (StateService.useIdleTimeFilter) StateService.FinalFilters.Add(new IdleTimeFilter(StateService.maxIdleHours));
        if (StateService.useMaxDailyCourses) StateService.FinalFilters.Add(new MaxDailyCoursesFilter(StateService.maxCoursesPerDay));
        if (StateService.useTotalCreditFilter) StateService.FinalFilters.Add(new TotalCreditFilter(StateService.minCredit, StateService.maxCredit));

        var service = new ScheduleService(
            maxPages: 50,
            realtimeFilters: StateService.RealtimeFilters,
            finalFilters: StateService.FinalFilters
        );

        // IAsyncEnumerable을 직접 순회합니다.
        await foreach (var schedule in service.GenerateSchedulesAsync(StateService.GroupedCourses))
        {
            StateService.generatedSchedules.Add(schedule);
            StateHasChanged(); // 결과가 나올 때마다 UI를 갱신
            await Task.Delay(1);
        }

        loading = false;
        StateHasChanged();
    }

    private void GoToMySchedules()
    {
        NavManager.NavigateTo("/myschedules");
    }

    private void GoToCourses()
    {
        NavManager.NavigateTo("/courses");
    }
}